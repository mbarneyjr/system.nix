Host i-*
  ProxyCommand sh -c 'host=%h; aws ec2-instance-connect send-ssh-public-key --instance-id $host --availability-zone $(aws ec2 describe-instances --instance-id $host --output text --query Reservations[].Instances[].Placement.AvailabilityZone) --instance-os-user ec2-user --ssh-public-key file://~/.ssh/id_ed25519.pub && aws ssm start-session --target $host --document-name AWS-StartSSHSession --parameters "portNumber=%p"'
  User ec2-user
